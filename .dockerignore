# Ignore Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore virtual environments
venv/
env/
.venv/
ENV/

# Ignore environment files
.env
.env.local

# Ignore git and editor files
.git/
.vscode/
.idea/

# Ignore logs and build artifacts
*.log
logs/
build/
dist/

# Ignore test files (if any)
tests/

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore local static files (if not needed in image)
