# MongoDB Connection
MONGODB_URL=mongodb://admin:password@central-mongodb:27017/vcard?authSource=admin
DATABASE_NAME=vcard
MAX_POOL_SIZE=10
MIN_POOL_SIZE=1

# Razorpay API Keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret


# JWT Authentication (IMPORTANT: Use strong, unique secrets in production)
# Example production-grade secrets (replace with your own secure values)
JWT_SECRET=prod_jwt_secret_3b7f8e2c9a1e4d5f8c7b6a9e2d1c4f7a
JWT_REFRESH_SECRET=prod_jwt_refresh_8e2c9a1e4d5f3b7f6a9e2d1c4f7b8c7a

# CORS (comma-separated origins, do NOT use * in production)
ALLOWED_ORIGINS=https://vcard.shoverhub.com,https://vcard-ui.pages.dev
