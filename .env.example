# MongoDB Connection
MONGODB_URL=mongodb://shoverhub:shoverhub@central-mongodb:27017/vcard?authSource=admin
DATABASE_NAME=vcard
MAX_POOL_SIZE=10
MIN_POOL_SIZE=1

# Razorpay API Keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# JWT Authentication (IMPORTANT: Set persistent secrets for production)
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# CORS (comma-separated origins, do NOT use * in production)
ALLOWED_ORIGINS=https://vcard.shoverhub.com,https://vcard-ui.pages.dev
